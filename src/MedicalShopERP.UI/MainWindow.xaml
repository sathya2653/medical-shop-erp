<Window x:Class="MedicalShopERP.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Medical Shop ERP - Login" Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    <Grid Background="#FFFFFF">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
            <!-- Header -->
            <TextBlock Text="Medical Shop ERP" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"
                       TextAlignment="Center" 
                       Margin="0,0,0,10" />
            <TextBlock Text="Login" 
                       FontSize="16" 
                       Foreground="#7F8C8D"
                       TextAlignment="Center" 
                       Margin="0,0,0,30" />

            <!-- Username -->
            <TextBlock Text="Username" FontSize="12" Foreground="#2C3E50" Margin="0,0,0,5" />
            <TextBox Name="UsernameTextBox" 
                     Height="40" 
                     Padding="10" 
                     FontSize="14" 
                     Background="#ECEFF1"
                     BorderThickness="1"
                     BorderBrush="#BDC3C7"
                     Margin="0,0,0,15" />

            <!-- Password -->
            <TextBlock Text="Password" FontSize="12" Foreground="#2C3E50" Margin="0,0,0,5" />
            <PasswordBox Name="PasswordBox" 
                         Height="40" 
                         Padding="10" 
                         FontSize="14" 
                         Background="#ECEFF1"
                         BorderThickness="1"
                         BorderBrush="#BDC3C7"
                         Margin="0,0,0,20" />

            <!-- Login Button -->
            <Button Name="LoginButton" 
                    Content="Login" 
                    Height="40" 
                    FontSize="14" 
                    FontWeight="Bold"
                    Background="#3498DB" 
                    Foreground="White"
                    Cursor="Hand"
                    Click="LoginButton_Click"
                    Margin="0,0,0,10" />

            <!-- Status Message -->
            <TextBlock Name="StatusMessage" 
                       Text="" 
                       Foreground="#E74C3C" 
                       TextAlignment="Center" 
                       Margin="0,10,0,0" 
                       FontSize="12" />
        </StackPanel>
    </Grid>
</Window>
